<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <submitter>Administrator</submitter>
        <type>role</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <submitter>PV_Manager</submitter>
        <type>role</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Account__c</field>
        <field>Opportunity__c</field>
        <field>Contract__c</field>
        <field>Agreement__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>joe.estes@perfect-vision.com</name>
                <type>user</type>
            </approver>
            <approver>
                <name>rebekka.neal@perfect-vision.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <description>This is the approval step that allows the agreement to be sent.</description>
        <label>Approve Agreement</label>
        <name>Approve_Agreement</name>
    </approvalStep>
    <description>This is the approval process that states all agreements must be approved before being sent to the dealer.</description>
    <emailTemplate>Approval_Process/Agreement_Approval_Process_Email_Template</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <formula>TEXT(Onboarding_Status__c) = &apos;Pending Approval&apos;</formula>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Onboarding_Status_Update_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Onboarding_Status_Update_Denied</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>Agreement_Approval</name>
            <type>Alert</type>
        </action>
    </initialSubmissionActions>
    <label>Agreement Approval Process</label>
    <processOrder>1</processOrder>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
</ApprovalProcess>
