    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Defines prerequisite relationships between External_Contact_Credential_Type__c records, ensuring certain credential types must be obtained before others can be issued. Enforces logical credential dependencies. Example: A dependency might specify that Credential_Type__c=&quot;OSHA 30 Certification&quot; requires Dependent_Credential_Type__c=&quot;OSHA 10 Certification&quot; to be completed first. This means a contact cannot obtain an OSHA 30 credential until they have an active OSHA 10 credential. The system can use these dependencies to validate credential issuance workflows and ensure contacts follow proper credential progression paths. This supports compliance requirements where advanced certifications depend on prerequisite certifications.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>false</enableReports>
    <enableSearch>false</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <label>External Credential Type Dependency</label>
    <nameField>
        <displayFormat>ECCTD-{00000}</displayFormat>
        <label>External Credential Type Dependency Numb</label>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>External Credential Type Dependencies</pluralLabel>
    <searchLayouts></searchLayouts>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
