<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Block_Mode__c</fullName>
    <fieldManageability>DeveloperControlled</fieldManageability>
    <inlineHelpText>Block Same Program: hides only the same vendor program (same retail option). Block Vendor On Any Complete: hides all programs for this vendor when any onboarding is in a completed status.</inlineHelpText>
    <label>Block Mode</label>
    <required>true</required>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Block Same Program</fullName>
                <default>true</default>
                <label>Block Same Program</label>
            </value>
            <value>
                <fullName>Block Vendor On Any Complete</fullName>
                <default>false</default>
                <label>Block Vendor On Any Complete</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
