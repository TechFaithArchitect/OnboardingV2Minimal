<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Agreement_Approval</fullName>
        <description>Agreement Approval</description>
        <protected>false</protected>
        <recipients>
            <recipient>joe.estes@perfect-vision.com</recipient>
            <type>user</type>
        </recipients>
        <recipients>
            <recipient>rebekka.neal@perfect-vision.com</recipient>
            <type>user</type>
        </recipients>
        <senderAddress>salesforceadmin@perfect-10.tv</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>Approval_Process/Agreement_Approval_Process_Email_Template</template>
    </alerts>
    <fieldUpdates>
        <fullName>Onboarding_Status_Update_Approved</fullName>
        <description>Update Onboarding Status to Agreement Approved</description>
        <field>Onboarding_Status__c</field>
        <literalValue>Approved</literalValue>
        <name>Onboarding Status Update</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Onboarding_Status_Update_Denied</fullName>
        <description>Set Onboarding Status to Denied</description>
        <field>Onboarding_Status__c</field>
        <literalValue>Denied</literalValue>
        <name>Onboarding Status Update</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
</Workflow>
