        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Create_Agreement_Record</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Yes - Send Documents</defaultConnectorLabel>
        <rules>
            <name>No_Send_Documents</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>OpportunityRecord.Documents_Ready__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <label>No - Do Not Send Documents</label>
        </rules>
    </decisions>
