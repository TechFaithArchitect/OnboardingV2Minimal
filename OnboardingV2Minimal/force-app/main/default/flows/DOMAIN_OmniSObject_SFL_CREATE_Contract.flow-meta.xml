    <description>DOMAIN LAYER - OmniSObject - Subflow - CREATE - Contract</description>
    <environments>Default</environments>
    <formulas>
        <name>contractTypeFormatted</name>
        <dataType>String</dataType>
        <expression>IF(
  OR(
    TEXT({!OpportunityRecord.Program_Base_App_Selection__c}) = &quot;Program Base Application - with Chuzo&quot;,
    TEXT({!OpportunityRecord.Program_Base_App_Selection__c}) = &quot;Program Base Application - without Chuzo&quot;,
    TEXT({!OpportunityRecord.Program_Base_App_Selection__c}) = &quot;Program Base Application - with Chuzo (No Personal Guarantee)&quot;,
    TEXT({!OpportunityRecord.Program_Base_App_Selection__c}) = &quot;Base Application - Infrastructure&quot;,
    TEXT({!OpportunityRecord.Program_Base_App_Selection__c}) = &quot;Not Applicable&quot;
  ),
  TEXT({!OpportunityRecord.Program_Base_App_Selection__c}),
  &quot;Vendor&quot;
)</expression>
    </formulas>
    <formulas>
        <name>ResolvedContractRecordTypeReferenceId</name>
        <dataType>String</dataType>
        <expression>IF(
  NOT(ISBLANK({!VendorProgram.Contract_Record_Type__c})),
  {!VendorProgram.Contract_Record_Type__c},
  {!HydratedVendorProgram.Contract_Record_Type__c}
)</expression>
    </formulas>
    <formulas>
        <name>ResolvedPrimaryContactId</name>
        <dataType>String</dataType>
        <expression>IF(
  NOT(ISBLANK({!OpportunityContactRole.ContactId})),
  {!OpportunityContactRole.ContactId},
  {!Get_Primary_Opportunity_Contact_For_Opportunity.ContactId}
)</expression>
    </formulas>
