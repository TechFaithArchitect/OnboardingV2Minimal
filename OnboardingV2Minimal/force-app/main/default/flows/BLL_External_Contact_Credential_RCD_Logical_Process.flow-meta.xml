        </outputAssignments>
    </subflows>
    <subflows>
        <name>Get_Onboarding_Records</name>
        <label>Get Onboarding Records</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_Contact_Signer_of_Contract</targetReference>
        </connector>
        <flowName>DOMAIN_OmniSObject_SFL_GET_Onboarding_Records</flowName>
        <inputAssignments>
            <name>AccountRecord</name>
            <value>
                <elementReference>AccountRecord</elementReference>
            </value>
        </inputAssignments>
        <outputAssignments>
