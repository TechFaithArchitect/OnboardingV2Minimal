<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Is_Agreement_Signed</name>
        <label>Is Agreement Signed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Agreement Is Not Signed or Is NDA</defaultConnectorLabel>
        <rules>
            <name>Agreement_is_Signed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.echosign_dev1__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Signed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.echosign_dev1__Contract__r.Contract_Type__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>NDA</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>LearnUpon_Training_Assignment_Process</targetReference>
            </connector>
            <label>Agreement is Signed</label>
        </rules>
    </decisions>
    <description>Business Logic Layer - Agreement Object - Record Trigger - Logic Process</description>
    <environments>Default</environments>
    <interviewLabel>BLL - Agreement - RCD - Logical Process {!$Flow.CurrentDateTime}</interviewLabel>
    <label>BLL - Agreement - RCD - Logical Process</label>
    <processMetadataValues>
