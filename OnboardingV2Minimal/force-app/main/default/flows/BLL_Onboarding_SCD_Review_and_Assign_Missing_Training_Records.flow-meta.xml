        <defaultConnectorLabel>No Match Found</defaultConnectorLabel>
        <rules>
            <name>Yes_Match_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Training_Assignments_Not_Assigned_to_Onboarding_Record.Vendor_Training_Requirement__r.Vendor_Customization__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
