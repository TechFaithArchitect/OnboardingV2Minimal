    <decisions>
        <name>Are_We_Sorting_Through_External_Or_Internal_Training</name>
        <label>Are We Sorting Through External Or Internal Training</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_Onboarding_Records_to_Update_Training_Assignments</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Training Requirement</defaultConnectorLabel>
        <rules>
            <name>Current_Onboarding_Training_Requirement_is_External</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Training_Requirement_to_Sort_Training_Required.Training_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>External</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Training_Assignments_Not_Assigned_to_Onboarding_Record</targetReference>
            </connector>
            <label>Current Onboarding Training Requirement is External</label>
        </rules>
        <rules>
            <name>Current_Onboarding_Training_Requirement_is_Internal</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Training_Requirement_to_Sort_Training_Required.Training_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Internal</stringValue>
