        <defaultConnectorLabel>Do Not Create Contract</defaultConnectorLabel>
        <rules>
            <name>New_Contract_Needs_to_be_Created</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Contracts_Associated_with_Account_and_Contract_Type.Id</leftValueReference>
