        </rules>
    </decisions>
    <description>DOMAIN LAYER - Onboarding Object - Subflow - CREATE - Contract</description>
    <environments>Default</environments>
    <formulas>
        <name>contractTypeFormatted</name>
        <dataType>String</dataType>
        <expression>IF(
  TEXT({!OnboardingRecord.Contract__r.Contract_Type__c}) = &quot;NDA&quot;,
  &quot;NDA&quot;,
  IF(
    OR(
      TEXT({!VendorProgram.Opportunity__r.Program_Base_App_Selection__c}) = &quot;Program Base Application - with Chuzo&quot;,
      TEXT({!VendorProgram.Opportunity__r.Program_Base_App_Selection__c}) = &quot;Program Base Application - without Chuzo&quot;,
      TEXT({!VendorProgram.Opportunity__r.Program_Base_App_Selection__c}) = &quot;Program Base Application - with Chuzo (No Personal Guarantee)&quot;,
       TEXT({!VendorProgram.Opportunity__r.Program_Base_App_Selection__c}) = &quot;Base Application - Infrastructure&quot;,
       TEXT({!VendorProgram.Opportunity__r.Program_Base_App_Selection__c}) = &quot;Not Applicable&quot;
    ),
          TEXT({!VendorProgram.Opportunity__r.Program_Base_App_Selection__c}),
    &quot;Vendor&quot;
  )
)</expression>
    </formulas>
