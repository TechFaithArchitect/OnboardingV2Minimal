    <recordCreates>
        <name>Create_Follow_Up_Queue_Record</name>
        <label>Create Follow Up Queue Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Attempt_Count__c</field>
            <value>
                <numberValue>1.0</numberValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Consecutive_Failures__c</field>
            <value>
                <numberValue>1.0</numberValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Error_Message__c</field>
            <value>
                <elementReference>ResolvedErrorMessage</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Follow_Up_Type__c</field>
            <value>
                <elementReference>ResolvedFollowUpType</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Last_Attempt_Date__c</field>
            <value>
                <elementReference>$Flow.CurrentDateTime</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Next_Attempt_Date__c</field>
            <value>
                <elementReference>NextRetryDateTime</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Onboarding__c</field>
            <value>
                <elementReference>OnboardingRecord.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status__c</field>
            <value>
                <stringValue>Pending Retry</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Trigger_Reason__c</field>
            <value>
                <elementReference>ResolvedTriggerReason</elementReference>
            </value>
        </inputAssignments>
        <object>Follow_Up_Queue__c</object>
    </recordCreates>
    <recordLookups>
        <name>Get_Existing_Follow_Up_Queue_Record</name>
        <label>Get Existing Follow Up Queue Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Existing_Queue_Record_Found</targetReference>
        </connector>
        <filterLogic>1 AND 2 AND 3 AND 4 AND 5</filterLogic>
        <filters>
            <field>Onboarding__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>OnboardingRecord.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Trigger_Reason__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>ResolvedTriggerReason</elementReference>
            </value>
        </filters>
        <filters>
            <field>Follow_Up_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>ResolvedFollowUpType</elementReference>
            </value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Sent</stringValue>
            </value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Resolved</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Follow_Up_Queue__c</object>
        <outputReference>ExistingFollowUpQueueRecord</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Attempt_Count__c</queriedFields>
        <queriedFields>Consecutive_Failures__c</queriedFields>
    </recordLookups>
