<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Existing_Queue_Record_Found</name>
        <label>Existing Queue Record Found</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Create_Follow_Up_Queue_Record</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Create New Queue Record</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ExistingFollowUpQueueRecord</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Follow_Up_Queue_Record</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>DOMAIN LAYER - OmniSObject - SFL - CREATE - Follow Up Queue</description>
    <environments>Default</environments>
    <formulas>
        <name>NextAttemptCount</name>
        <dataType>Number</dataType>
        <expression>IF(
  ISBLANK({!ExistingFollowUpQueueRecord.Attempt_Count__c}),
  1,
  {!ExistingFollowUpQueueRecord.Attempt_Count__c} + 1
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>NextConsecutiveFailures</name>
        <dataType>Number</dataType>
        <expression>IF(
  ISBLANK({!ExistingFollowUpQueueRecord.Consecutive_Failures__c}),
  1,
  {!ExistingFollowUpQueueRecord.Consecutive_Failures__c} + 1
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>NextRetryDateTime</name>
        <dataType>DateTime</dataType>
        <expression>{!$Flow.CurrentDateTime} + (1/24)</expression>
    </formulas>
    <formulas>
        <name>ResolvedErrorMessage</name>
        <dataType>String</dataType>
        <expression>IF(
  ISBLANK({!ErrorMessage}),
  &quot;Communication dispatch failed in async flow.&quot;,
  {!ErrorMessage}
)</expression>
    </formulas>
    <formulas>
        <name>ResolvedFollowUpType</name>
        <dataType>String</dataType>
        <expression>IF(
  ISBLANK({!FollowUpType}),
  &quot;Email&quot;,
  {!FollowUpType}
)</expression>
    </formulas>
    <formulas>
        <name>ResolvedTriggerReason</name>
        <dataType>String</dataType>
        <expression>IF(
  ISBLANK({!TriggerReason}),
  &quot;COMMUNICATION_DISPATCH&quot;,
  {!TriggerReason}
)</expression>
    </formulas>
    <interviewLabel>DOMAIN - OmniSObject - SFL - CREATE - Follow Up Queue {!$Flow.CurrentDateTime}</interviewLabel>
    <label>DOMAIN - OmniSObject - SFL - CREATE - Follow Up Queue</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
