        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>ExistingFollowUpQueueRecord.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Attempt_Count__c</field>
            <value>
                <elementReference>NextAttemptCount</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Consecutive_Failures__c</field>
            <value>
                <elementReference>NextConsecutiveFailures</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Error_Message__c</field>
            <value>
                <elementReference>ResolvedErrorMessage</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Last_Attempt_Date__c</field>
            <value>
                <elementReference>$Flow.CurrentDateTime</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Next_Attempt_Date__c</field>
            <value>
                <elementReference>NextRetryDateTime</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status__c</field>
            <value>
                <stringValue>Pending Retry</stringValue>
            </value>
        </inputAssignments>
        <object>Follow_Up_Queue__c</object>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Existing_Follow_Up_Queue_Record</targetReference>
        </connector>
    </start>
