            <inputParameters>
                <name>VendorProgramId</name>
            </inputParameters>
            <inputParameters>
                <name>VendorProgramRecord</name>
            </inputParameters>
            <inputParameters>
                <name>VendorProgramRecordCollection</name>
            </inputParameters>
            <inputParameters>
                <name>VendorProgramRecordList</name>
            </inputParameters>
            <label>Get Onboarding Records</label>
            <outputConfigParams>
                <name>HasAnyOboardingForAccount</name>
                <value xsi:nil="true"/>
            </outputConfigParams>
            <outputConfigParams>
                <name>HasChuzoOnboardingForOpportunity</name>
                <value xsi:nil="true"/>
            </outputConfigParams>
            <outputConfigParams>
