                <name>OnboardingId</name>
            </inputParameters>
            <inputParameters>
                <name>OpportunityId</name>
            </inputParameters>
            <inputParameters>
                <name>OpportunityRecord</name>
            </inputParameters>
            <inputParameters>
                <name>OpportunityRecordCollection</name>
            </inputParameters>
            <inputParameters>
                <name>OpportunityRecordList</name>
            </inputParameters>
            <inputParameters>
                <name>TrainingAssignmentRecord</name>
