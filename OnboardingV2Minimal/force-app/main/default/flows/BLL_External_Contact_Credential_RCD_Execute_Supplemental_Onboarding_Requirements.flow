            <inputParameters>
                <name>AgreementRecordList</name>
            </inputParameters>
            <inputParameters>
                <name>ContactId</name>
            </inputParameters>
            <inputParameters>
                <name>ContractId</name>
            </inputParameters>
            <inputParameters>
                <name>ContractRecord</name>
            </inputParameters>
            <inputParameters>
                <name>ContractRecordCollection</name>
